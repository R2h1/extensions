{
  "manifest_version": 3,
  "name": "闲页",
  "version": "0.2.0",
  "description": "清闲的新标签页摸鱼面板",

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "declarativeNetRequestWithHostAccess",
    "bookmarks",
    "favicon"
  ],

  "host_permissions": [
    "https://goldprice.today/*",
    "https://fundgz.1234567.com.cn/*",
    "https://api.open-meteo.com/*",
    "https://geocoding-api.open-meteo.com/*",
    "https://air-quality-api.open-meteo.com/*",
    "https://weibo.com/*",
    "https://api.bilibili.com/*",
    "https://top.baidu.com/*",
    "https://api.i-meto.com/*",
    "https://timor.tech/*",
    "https://api.juejin.cn/*",
    "https://news-at.zhihu.com/*",
    "https://zhibo.sina.com.cn/*",
    "https://*.music.126.net/*",
    "https://weread.qq.com/*",
    "https://i.weread.qq.com/*",
    "https://open.er-api.com/*",
    "https://aihot.virxact.com/*"
  ],
  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "weibo_referer",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  }
}