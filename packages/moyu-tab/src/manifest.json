{
  "manifest_version": 3,
  "name": "工位搭子",
  "version": "0.2.0",
  "description": "你的新标签页摸鱼搭子",

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ]
}