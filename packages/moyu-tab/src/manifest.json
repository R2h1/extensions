{
  "manifest_version": 3,
  "name": "闲页",
  "version": "0.2.0",
  "description": "清闲的新标签页摸鱼面板",

  "chrome_url_overrides": {
    "newtab": "newtab/newtab.html"
  },

  "background": {
    "service_worker": "background/sw.js",
    "type": "module"
  },

  "permissions": [
    "storage",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://goldprice.today/*",
    "https://fundgz.1234567.com.cn/*"
  ]
}